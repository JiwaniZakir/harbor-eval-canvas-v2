# Harbor Eval Canvas V2 - Environment Variables
# Copy to .env.local and fill in values.

# --- Google Gemini (agent interactions) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Supabase ---
# LOCAL DEV: run `supabase start` and copy the values from `supabase status`.
#   NEXT_PUBLIC_SUPABASE_URL  -> "Project URL" (http://127.0.0.1:54321)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY -> the "Publishable" key (sb_publishable_...)
#   SUPABASE_SERVICE_ROLE_KEY     -> the "Secret" key (sb_secret_...)
#
# PRODUCTION: create a Supabase cloud project at https://supabase.com/dashboard,
# run the migrations against it (`supabase link` + `supabase db push`), then copy
# the values from Project Settings -> API and set them in your hosting provider
# (e.g. Vercel project env vars). NEVER expose SUPABASE_SERVICE_ROLE_KEY to the
# browser; it is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# --- App URL (for OG images / auth redirects) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
